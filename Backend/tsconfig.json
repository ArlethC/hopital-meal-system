{
  "compilerOptions": {
    "target": "ES2020",                         
    "module": "node16",                      
    "rootDir": "./src",                          
    "outDir": "./dist",                        
    "strict": true,                              
    "esModuleInterop": true,                    
    "forceConsistentCasingInFileNames": true,    
    "moduleResolution": "node16",                  
    "resolveJsonModule": true,                   
    "experimentalDecorators": true,              
    "emitDecoratorMetadata": true,               
    "skipLibCheck": true                         
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
